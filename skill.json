{
  "name": "context-saver",
  "version": "4.0.0",
  "description": "MCP server for AI agent context window optimization — sandboxed execution, intent filtering, FTS5 knowledge base, session continuity, multi-messenger delivery",
  "type": "mcp-server",
  "transport": "stdio",
  "command": "node",
  "args": ["dist/server.js"],
  "tools": [
    "ctx_execute",
    "ctx_execute_file",
    "ctx_batch",
    "ctx_search",
    "ctx_index",
    "ctx_fetch_index",
    "ctx_session",
    "ctx_stats",
    "ctx_deliver",
    "ctx_doctor"
  ],
  "capabilities": [
    "sandboxed-execution",
    "intent-filtering",
    "fts5-knowledge-base",
    "session-continuity",
    "multi-messenger-delivery",
    "zero-token-pipelines",
    "verbose-injection",
    "compact-by-default"
  ],
  "outputSchema": {
    "success": "boolean",
    "summary": "string",
    "bytes_saved": "number",
    "data": "object"
  },
  "sla": { "maxLatencyMs": 30000, "availability": 0.99 },
  "permissions": ["exec:skills", "fs:context/*", "net:http", "net:https"]
}
